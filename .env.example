# OffGridAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Node Network ────────────────────────────────────────────────────────────
AIPI_IP=192.168.1.x          # Primary node (Hailo-8) local IP
JOLLY_IP=192.168.1.x         # RPC worker node local IP
JOLLY_TAILSCALE_IP=100.x.x.x # RPC worker Tailscale IP (fallback)

# ─── HuggingFace ─────────────────────────────────────────────────────────────
HF_TOKEN=hf_...              # Read token for gated model downloads
                              # Create at: huggingface.co/settings/tokens

# ─── Open WebUI ──────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=            # Generate: openssl rand -hex 32

# ─── User ────────────────────────────────────────────────────────────────────
CLUSTER_USER=merry           # Unix user that owns all services
